{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Candy",
  "scopeName": "source.candy",
  "patterns": [
    {
      "include": "#use"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "use": {
      "patterns": [
        {
          "name": "meta.declaration.use.candy",
          "begin": "\\b(use)(\\s*)(\\()",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.candy"
            },
            "3": {
              "name": "punctuation.section.parens.begin.candy"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parens.end.candy"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "name": "keyword.control.import.as.candy",
              "match": "\\bas\\b"
            },
            {
              "name": "entity.name.namespace.alias.candy",
              "match": "(?<=\\bas\\s)[A-Za-z_][A-Za-z0-9_]*"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.candy",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.candy"
            }
          },
          "end": "$"
        },
        {
          "name": "comment.block.candy",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.candy"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.candy"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.candy",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.candy"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.candy"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.candy",
              "match": "\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})"
            }
          ]
        },
        {
          "name": "string.quoted.single.candy",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.candy"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.candy"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.candy",
              "match": "\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})"
            }
          ]
        },
        {
          "name": "string.quoted.other.raw.candy",
          "begin": "`",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.candy"
            }
          },
          "end": "`",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.candy"
            }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.annotation.candy",
          "begin": "#\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.annotation.begin.candy"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.annotation.end.candy"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#calls"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            },
            {
              "name": "entity.other.attribute-name.candy",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(let)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.variable.candy"
            },
            "3": {
              "name": "variable.other.readwrite.candy"
            }
          }
        },
        {
          "match": "\\b(as)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.as.candy"
            },
            "3": {
              "name": "entity.name.namespace.alias.candy"
            }
          }
        },
        {
          "name": "entity.name.type.candy",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\{)"
        },
        {
          "name": "variable.other.member.candy",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*:(?!:))"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.candy",
          "match": "\\b(?:package|use|pub|let)\\b"
        },
        {
          "name": "keyword.control.import.as.candy",
          "match": "\\bas\\b"
        },
        {
          "name": "constant.language.boolean.candy",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.candy",
          "match": "\\b(?:bool|char|complex|error|float|int|string)\\b"
        },
        {
          "name": "storage.modifier.pointer.candy",
          "match": "\\*(?=(?:\\[\\])?\\*?[A-Za-z_])"
        },
        {
          "name": "storage.modifier.slice.candy",
          "match": "\\[\\](?=\\*?[A-Za-z_])"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "entity.name.namespace.candy",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*::)"
        },
        {
          "name": "entity.name.function.candy",
          "match": "(?:(?<=\\.)|(?<=::))\\s*\\K[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.candy",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.namespace.candy",
          "match": "(?<=::)\\s*\\K[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.other.property.candy",
          "match": "(?<=\\.)\\s*\\K[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.imaginary.candy",
          "match": "(?<![A-Za-z0-9_])(?:0[xX][0-9A-Fa-f]+|0[bB][01]+|0[oO][0-7]+|(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)i\\b"
        },
        {
          "name": "constant.numeric.float.candy",
          "match": "(?<![A-Za-z0-9_])(?:[0-9]+\\.[0-9]*|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.candy",
          "match": "(?<![A-Za-z0-9_])(?:0[xX][0-9A-Fa-f]+|0[bB][01]+|0[oO][0-7]+|[0-9]+)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.candy",
          "match": "->|<-"
        },
        {
          "name": "keyword.operator.namespace.candy",
          "match": "::"
        },
        {
          "name": "keyword.operator.assignment.candy",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.candy",
          "match": "[+\\-*/%^]"
        },
        {
          "name": "keyword.operator.access.candy",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "invalid.illegal.comma.candy",
          "match": ","
        },
        {
          "name": "invalid.illegal.semicolon.candy",
          "match": ";"
        },
        {
          "name": "punctuation.separator.type.candy",
          "match": ":(?!:)"
        },
        {
          "name": "punctuation.section.parens.begin.candy",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.candy",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.block.begin.candy",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.candy",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.candy",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.candy",
          "match": "\\]"
        }
      ]
    }
  }
}
