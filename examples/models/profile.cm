package("main")

go::model Profile {
    pub displayName: string = "Guest"
    pub age: int = 18
    pub active: bool = true
    pub tags: []string = []string{"new", "reader"}
}

let guest: Profile = Profile{
    displayName: "Guest"
    age: 18
    active: true
    tags: []string{"new", "reader"}
}

let owner: *Profile = &Profile{
    displayName: "Owner"
    age: 30
    active: true
    tags: []string{"admin"}
}
