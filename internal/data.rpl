package models

attrs (
	"rpl:sql"
)

import (
	time "time"
)

@sql(db: "sqlite", table: "CacheCliText")
model CacheCliText {
	Lang string @sql(index: true)
	OriginalText string @sql(index: true)
	Text string
	CreatedAt time.Time @sql(default: "now")
}

@sql(db: "sqlite", table: "Plugins")
model Plugins {
	Plugins []SqlPlugin
}

model SqlPlugin {
	Plugin Plugin
	UpdateAt time.Time @sql(default: "now", updatedAt: true)
	CreatedAt time.Time @sql(default: "now")
}
